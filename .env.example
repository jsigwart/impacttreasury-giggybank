# =============================================================================
# GiggyBank Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# --- Database (any Postgres: Supabase, Neon, self-hosted, etc.) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Gemini / Nano Banana (Image Generation) ---
GEMINI_API_KEY=

# --- S3-Compatible Image Hosting (AWS S3 or self-hosted MinIO) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# For self-hosted MinIO, set these two instead of using AWS:
# S3_ENDPOINT=http://your-vps-ip:9000
# S3_PUBLIC_URL=http://your-vps-ip:9000

# --- NFT Minting (Metaplex) ---
CREATOR_PRIVATE_KEY=          # Base58-encoded private key for the NFT creator/collection authority wallet
COLLECTION_MINT_ADDRESS=      # Output from: npx ts-node scripts/create-collection.ts
